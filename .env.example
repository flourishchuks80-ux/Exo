# ─── Privy ──────────────────────────────────────────────────────────────────
# Get your app ID and secret at https://dashboard.privy.io → Settings → API Keys
NEXT_PUBLIC_PRIVY_APP_ID=
# Required for Telegram mini-app server-assisted key derivation
PRIVY_APP_SECRET=

# ─── AI Model API Keys (server-side only — never exposed to browser) ─────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
# Your deployment URL — used for generating share links
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Seed Script (only needed for running scripts/seed.ts) ───────────────────
# A wallet with GLM tokens on Arkiv Braga testnet
# Get GLM from the Braga faucet: https://braga.hoodi.arkiv.network/faucet
SEED_PRIVATE_KEY=
SEED_WALLET_ADDRESS=
